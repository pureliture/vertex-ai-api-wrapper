# 서비스 계정 키 경로 (ADC). Vertex AI User(roles/aiplatform.user) 권한 필요.
GOOGLE_APPLICATION_CREDENTIALS=/app/secrets/vertex-sa.json

# GCP 프로젝트 / 리전 (RAGFlow와 가까운 리전 권장)
VERTEX_PROJECT=your-gcp-project
VERTEX_LOCATION=us-central1

# RAGFlow에서 임베딩 호출 기본 task_type (문서 색인용)
VERTEX_TASK_TYPE_DEFAULT=RETRIEVAL_DOCUMENT

# 입력 토큰 초과 시 자동 절단 (false면 한도 초과 시 400)
VERTEX_AUTO_TRUNCATE=true

# 래퍼 보호용 키. 설정 시 RAGFlow의 API-Key 칸에 동일 값 입력. 같은 Docker망이면 비워도 됨.
WRAPPER_API_KEY=

# 토큰 만료 몇 초 전에 선갱신할지
TOKEN_REFRESH_SKEW_SECONDS=300

# Vertex 동시 호출 상한 / HTTP 타임아웃
MAX_CONCURRENCY=8
HTTP_TIMEOUT_SECONDS=60

# KNOWN_MAX_INSTANCES에 없는 모델의 요청당 instance 폴백(안전값 1)
DEFAULT_MAX_INSTANCES=1

# 허용 모델 화이트리스트 추가(쉼표구분). 기본 3개 외 Vertex 임베딩 모델을 쓸 때만 추가.
# 여기 없는 model 이름은 404로 거부됨(path 주입 방지). 예: EXTRA_MODELS=text-embedding-004
EXTRA_MODELS=
